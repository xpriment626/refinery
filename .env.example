# Local Refinery instance location. Defaults to ./refinery/.refinery when unset.
# REFINERY_HOME=/absolute/path/to/refinery-instance

# Local specialist model configuration. Refinery defaults to Coral Cloud's
# OpenAI-compatible DeepSeek proxy. For packaged use, prefer:
#   refinery set auth coral
# CORAL_API_KEY remains supported for repo-local development and CI.
REFINERY_MODEL_PROVIDER=coral
REFINERY_MODEL_BASE_URL=https://llm.coralcloud.ai/deepseek/v1
REFINERY_MODEL_NAME=deepseek-v4-pro
CORAL_API_KEY=

# Future MCP/API hosting knobs. Stage A MCP currently runs over stdio.
REFINERY_API_HOST=127.0.0.1
REFINERY_API_PORT=8765
