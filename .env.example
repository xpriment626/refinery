# Local Refinery instance location. Defaults to ./refinery/.refinery when unset.
# REFINERY_HOME=/absolute/path/to/refinery-instance

# Future local specialist model configuration. The current scaffold does not
# call a live LLM endpoint. First LLM test path is expected to use OpenRouter's
# OpenAI-compatible API with DeepSeek V4 Pro.
REFINERY_MODEL_PROVIDER=openrouter
REFINERY_MODEL_BASE_URL=https://openrouter.ai/api/v1
REFINERY_MODEL_NAME=deepseek/deepseek-v4-pro
OPENROUTER_API_KEY=

# Future MCP/API hosting knobs. Stage A MCP currently runs over stdio.
REFINERY_API_HOST=127.0.0.1
REFINERY_API_PORT=8765
